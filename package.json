{
  "name": "investment-research-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "data:research": "node -e \"console.log('See docs/a-stock-data-usage-notes.md and docs/a-stock-data-field-mapping.md')\"",
    "data:universe": "node scripts/generate-stock-universe.mjs",
    "data:fetch": "npm run data:universe && python scripts/fetch-a-stock-data.py && python scripts/fetch-hk-stock-data.py",
    "data:fetch:a-stock": "npm run data:universe && python scripts/fetch-a-stock-data.py",
    "data:fetch:hk": "npm run data:universe && python scripts/fetch-hk-stock-data.py",
    "data:fetch:macro": "python scripts/fetch-macro-data.py",
    "data:validate": "npm run data:universe && python scripts/validate-a-stock-data.py",
    "data:validate:a-stock": "npm run data:universe && python scripts/validate-a-stock-data.py",
    "data:audit": "node scripts/data-audit.mjs",
    "data:refresh": "npm run data:universe && npm run data:fetch:a-stock && npm run data:fetch:hk && npm run data:fetch:macro && npm run data:validate:a-stock",
    "ui:audit": "node scripts/ui-audit.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.6"
  }
}
